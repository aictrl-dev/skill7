{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@aictrl/plugin",
  "version": "1.2.16",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aictrl-dev/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "exports": {
    ".": "./src/index.ts",
    "./tool": "./src/tool.ts"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@aictrl/sdk": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tsconfig/node22": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "@typescript/native-preview": "catalog:"
  }
}
