{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": ["CI", "AICTRL_DISABLE_SHARE"],
  "globalPassThroughEnv": ["CI", "AICTRL_DISABLE_SHARE"],
  "tasks": {
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
